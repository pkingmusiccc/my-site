# Copy to .env.local and fill in. Never commit .env.local.

# --- Enquiry form ---------------------------------------------------------
# Resend API key for transactional email. https://resend.com
RESEND_API_KEY=

# Destination email for partnership enquiries. e.g. partners@vitracosmetics.ch
ENQUIRY_INBOX=

# Verified sender address (must be a domain verified in your Resend account).
# e.g. "Vitracosmetics <no-reply@vitracosmetics.ch>"
ENQUIRY_FROM=

# --- Public site ----------------------------------------------------------
# Used for absolute URLs in metadata, OG tags, sitemap. Swap when domain confirmed.
NEXT_PUBLIC_SITE_URL=https://vitracosmetics.ch

# --- Analytics (optional, privacy-first) ----------------------------------
# Set to enable Plausible. Leave blank to disable analytics entirely.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
